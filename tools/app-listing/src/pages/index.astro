---
import { SLIDES } from '../lib/slides';

const groups = [...new Set(SLIDES.map((s) => s.group))].map((g) => ({
  name: g,
  items: SLIDES.filter((s) => s.group === g),
}));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>QSortby · Listing Studio</title>
    <style>
      :root {
        --ink: #101317; --ink-2: #41464d; --muted: #697079; --line: #e6e7ea;
        --green: #00a36b; --green-ink: #067a55; --green-soft: #e9f6f0; --green-line: #cbe8da;
        --panel: #0e1116; --panel-2: #161b22; --panel-line: #232a33; --panel-mut: #8b94a0;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body { font-family: 'Inter', system-ui, -apple-system, sans-serif; color: var(--ink); background: #f4f5f6;
        display: grid; grid-template-columns: 296px 1fr; height: 100vh; overflow: hidden; }

      /* ---- sidebar ---- */
      .side { background: var(--panel); color: #e7ebf0; display: flex; flex-direction: column; overflow-y: auto; }
      .side .brand { display: flex; align-items: center; gap: 11px; padding: 20px 20px 18px; border-bottom: 1px solid var(--panel-line); }
      .side .brand svg { width: 30px; height: 30px; }
      .side .brand b { font-weight: 700; font-size: 15px; letter-spacing: -.02em; }
      .side .brand small { display: block; font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--green); font-weight: 600; margin-top: 2px; }
      .grp { padding: 18px 14px 4px; }
      .grp h3 { font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--panel-mut); margin: 0 0 8px; padding: 0 8px; }
      .item { display: block; width: 100%; text-align: left; border: 1px solid transparent; background: transparent; color: #d3d9e0; padding: 11px 12px; border-radius: 10px; cursor: pointer; transition: background .12s, border-color .12s; }
      .item:hover { background: var(--panel-2); }
      .item.on { background: var(--panel-2); border-color: var(--panel-line); }
      .item .t { font-size: 13.5px; font-weight: 600; letter-spacing: -.01em; }
      .item.on .t { color: #fff; }
      .item .n { font-size: 11.5px; color: var(--panel-mut); margin-top: 3px; line-height: 1.3; }
      .item .dim { font-size: 10.5px; font-family: ui-monospace, monospace; color: var(--green); margin-top: 5px; }
      .side .foot { margin-top: auto; padding: 14px 22px; border-top: 1px solid var(--panel-line); font-size: 11px; color: var(--panel-mut); line-height: 1.5; }
      .side .foot code { color: #cdd4dd; }

      /* ---- main ---- */
      .main { display: flex; flex-direction: column; min-width: 0; }
      .bar { display: flex; align-items: center; gap: 16px; padding: 0 22px; height: 62px; background: #fff; border-bottom: 1px solid var(--line); }
      .bar .ttl { font-weight: 600; font-size: 15px; letter-spacing: -.01em; }
      .bar .ttl span { color: var(--muted); font-family: ui-monospace, monospace; font-size: 12px; margin-left: 10px; font-weight: 500; }
      .bar .sp { flex: 1; }
      .bar label { font-size: 12px; color: var(--muted); display: inline-flex; align-items: center; gap: 7px; }
      .bar select { font: inherit; font-size: 13px; padding: 7px 9px; border: 1px solid var(--line); border-radius: 9px; background: #fff; cursor: pointer; }
      .btn { font: inherit; font-size: 13px; font-weight: 600; padding: 9px 15px; border-radius: 10px; border: 1px solid var(--line); background: #fff; color: var(--ink); cursor: pointer; transition: border-color .12s, background .12s, transform .1s; }
      .btn:hover { border-color: #c2c6cc; }
      .btn:active { transform: translateY(1px); }
      .btn.pri { background: var(--ink); color: #fff; border-color: var(--ink); }
      .btn.pri:hover { background: #2a2f37; }
      .btn[disabled] { opacity: .55; cursor: default; }

      .stage { flex: 1; min-height: 0; display: grid; place-items: center;
        background:
          radial-gradient(60% 60% at 50% 0%, rgba(0,163,107,.06), transparent 70%),
          #eef0f2;
        background-image: radial-gradient(rgba(16,24,40,.05) 1px, transparent 1px); background-size: 22px 22px; }
      .frame { position: relative; border-radius: 14px; overflow: hidden; box-shadow: 0 1px 1px rgba(16,24,40,.05), 0 30px 70px -28px rgba(16,24,40,.4); background: #fff; }
      .frame iframe { border: 0; transform-origin: top left; display: block; }

      .toast { position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%) translateY(20px); opacity: 0; transition: .25s; background: var(--ink); color: #fff; font-size: 13px; padding: 11px 17px; border-radius: 11px; box-shadow: 0 18px 40px -16px rgba(16,24,40,.5); max-width: 70vw; pointer-events: none; }
      .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
      .toast b { color: var(--green-bright, #2bd996); }
      .spin { width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.35); border-top-color: #fff; border-radius: 50%; display: inline-block; vertical-align: -2px; margin-right: 8px; animation: sp .7s linear infinite; }
      @keyframes sp { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>
    <nav class="side">
      <div class="brand">
        <svg viewBox="0 0 32 32" fill="none"><rect x="2.5" y="2.5" width="27" height="27" rx="7" stroke="#fff" stroke-width="2"/><rect x="13.25" y="7.6" width="5.5" height="5.5" rx="1.5" fill="#0e9d63"/><rect x="13.25" y="13.75" width="5.5" height="5.5" rx="1.5" fill="#0e9d63" fill-opacity="0.55"/><rect x="13.25" y="19.9" width="5.5" height="5.5" rx="1.5" fill="#0e9d63" fill-opacity="0.28"/></svg>
        <div><b>Listing Studio</b><small>QSortby</small></div>
      </div>
      {groups.map((g) => (
        <div class="grp">
          <h3>{g.name}</h3>
          {g.items.map((s) => (
            <button class="item" data-id={s.id} data-w={s.width} data-h={s.height}>
              <div class="t">{s.title}</div>
              <div class="n">{s.note}</div>
              <div class="dim">{s.width}×{s.height}</div>
            </button>
          ))}
        </div>
      ))}
      <div class="foot">Export writes PNGs to <code>design-hub/exports/</code>. Rendered at the chosen supersample, downscaled to exact size.</div>
    </nav>

    <div class="main">
      <div class="bar">
        <div class="ttl" id="bar-title">Feature image <span id="bar-dim">1600×900</span></div>
        <div class="sp"></div>
        <label>Quality
          <select id="ss"><option value="1">1× (exact)</option><option value="2" selected>2× (crisp)</option><option value="3">3× (max)</option></select>
        </label>
        <button class="btn" id="ex-one">Export PNG</button>
        <button class="btn pri" id="ex-all">Export all</button>
      </div>
      <div class="stage">
        <div class="frame" id="frame"><iframe id="pv" src="/render/feature-image"></iframe></div>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <script define:vars={{ slides: SLIDES }}>
      let current = slides[0];

      const pv = document.getElementById('pv');
      const frame = document.getElementById('frame');
      const stage = document.querySelector('.stage');

      function fit() {
        const pad = 56;
        const sw = stage.clientWidth - pad;
        const sh = stage.clientHeight - pad;
        const scale = Math.min(sw / current.width, sh / current.height, 1);
        pv.style.width = current.width + 'px';
        pv.style.height = current.height + 'px';
        pv.style.transform = 'scale(' + scale + ')';
        frame.style.width = current.width * scale + 'px';
        frame.style.height = current.height * scale + 'px';
      }

      function select(id) {
        current = slides.find((s) => s.id === id);
        document.querySelectorAll('.item').forEach((b) => b.classList.toggle('on', b.dataset.id === id));
        document.getElementById('bar-title').firstChild.textContent = current.title + ' ';
        document.getElementById('bar-dim').textContent = current.width + '×' + current.height;
        pv.src = '/render/' + id;
        fit();
      }

      document.querySelectorAll('.item').forEach((b) =>
        b.addEventListener('click', () => select(b.dataset.id))
      );
      window.addEventListener('resize', fit);
      pv.addEventListener('load', fit);
      select(current.id);

      const toast = document.getElementById('toast');
      let toastTimer;
      function showToast(html, sticky) {
        toast.innerHTML = html;
        toast.classList.add('show');
        clearTimeout(toastTimer);
        if (!sticky) toastTimer = setTimeout(() => toast.classList.remove('show'), 4200);
      }

      async function runExport(id, btn) {
        const buttons = document.querySelectorAll('.btn');
        buttons.forEach((b) => (b.disabled = true));
        showToast('<span class="spin"></span>Rendering ' + (id === 'all' ? 'all slides' : id) + '…', true);
        try {
          const ss = Number(document.getElementById('ss').value);
          const res = await fetch('/api/export', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ id, supersample: ss }),
          });
          const data = await res.json();
          if (!data.ok) throw new Error('export failed');
          showToast('Saved <b>' + data.results.length + '</b> PNG' + (data.results.length > 1 ? 's' : '') + ' → <b>exports/</b>');
        } catch (e) {
          showToast('Export failed — is the dev server healthy? ' + (e.message || ''));
        } finally {
          buttons.forEach((b) => (b.disabled = false));
        }
      }

      document.getElementById('ex-one').addEventListener('click', () => runExport(current.id));
      document.getElementById('ex-all').addEventListener('click', () => runExport('all'));
    </script>
  </body>
</html>
